    {
      "id": "proj_resolve_it_llm_powered_andon_cord",
      "type": "project",
      "label": "Resolve-It — LLM Powered Andon Cord",
      "org": "org_amazon",
      "summary": "Built an LLM-powered Andon Cord enabling auditors to raise SOP doubts from GeoStudio in one click. System performs semantic retrieval against Policy 2.0 and verified responses, generates AI suggestions for POC validation, and delivers resolutions in ~5 minutes. Implements Human Feedback Reinforcement Learning — managers approve, reject, or edit responses daily, making the system self-improving. Impact: ~200 min/day recovered across 20 auditors."
    },
    {
      "id": "proj_real_time_revert_dashboard",
      "type": "project",
      "label": "Real-Time Revert Dashboard",
      "org": "org_amazon",
      "summary": "Built an internal web application transforming manual quality reporting into an always-current intelligence platform. Managers upload daily revert case batches; system auto-identifies unique cases and computes role-aware KPIs on every page request — Pre-Appeal Quality, Post-Appeal Quality, Volume Trends, and Reason Distribution. Role-based views for auditors, managers, and skip-level leaders — eliminating ad-hoc reporting entirely."
    },
    {
      "id": "proj_slack_workflow_based_andon_cord",
      "type": "project",
      "label": "Slack Workflow Based Andon Cord",
      "org": "org_amazon",
      "summary": "Deployed a Slack-integrated anonymous doubt resolution workflow enabling auditors to raise SOP, process, and tool queries while maintaining complete anonymity. Each submission receives a unique Ticket ID, routed to managers with Answer, Assign, or Check Status options. Resolutions delivered via Slack DM and posted in team channel for organization-wide reference — ensuring consistent understanding of dynamic procedures."
    },
    {
      "id": "proj_aws_hosted_sla_engine_and_dashboard_for_",
      "type": "project",
      "label": "AWS Hosted SLA Engine and Dashboard for Slack Workflow",
      "org": "org_amazon",
      "summary": "Engineered an SLA tracking engine monitoring ticket lifecycle metrics — raise-to-resolution time, escalation rates, and manager approval timelines. Unresolved tickets beyond SLA are automatically escalated to leadership, ensuring zero unanswered queries. Monitoring dashboard provides leadership real-time visibility into resolution health and SLA compliance."
    },
    {
      "id": "proj_project_prophesy",
      "type": "project",
      "label": "Project Prophesy",
      "org": "org_amazon",
      "summary": "Built a proactive detection mechanism that flags repeat-defect addresses prone to escalation using multi-signal analysis, shifting defect handling from reactive to preventive."
    },
    {
      "id": "proj_project_polygon",
      "type": "project",
      "label": "Project Polygon",
      "org": "org_amazon",
      "summary": "Reduced Shipping & Delivery Support (SDS) expenditure by enriching the learning datasets for Global Address Management (GAM) addresses that map to multiple delivery locations."
    },
    {
      "id": "proj_project_place_based_geocoding",
      "type": "project",
      "label": "Project Place Based Geocoding",
      "org": "org_amazon",
      "summary": "Merged the GAM and Geo-Tech address systems onto a single Place-Based Geocoding (PBG) learning model, eliminating the data dispersion caused by maintaining two disparate systems."
    },
    {
      "id": "proj_data_mining",
      "type": "project",
      "label": "Data Mining",
