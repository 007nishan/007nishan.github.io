{% extends "base.html.j2" %}

{% block content %}
<h1 class="page-title">Friends' Testimonials</h1>
<p class="page-intro">What colleagues and peers say.</p>

<div class="section">
  {%- set real = testimonials | selectattr('quote') | list %}
  {%- if real %}
  <div class="cards">
    {%- for t in real %}
    <div class="card">
      <p>“{{ t.quote }}”</p>
      <p class="muted">— {{ t.author }}{% if t.role %}, {{ t.role }}{% endif %}</p>
    </div>
    {%- endfor %}
  </div>
  {%- else %}
  <div class="callout">
    <p>Testimonials coming soon. To add one, edit <code>x_testimonials</code> in <code>data/resume.json</code> — it renders here automatically on the next build.</p>
  </div>
  {%- endif %}
</div>
{% endblock %}
