{#- PUBLIC CV page. Single, self-contained page — no multi-page nav, no links to
    internal/pipeline pages. This is the ONLY page published to the live site. -#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ basics.name }} — CV</title>
  <meta name="description" content="{{ page_description }}">
  <meta name="author" content="{{ basics.name }}">
  <link rel="canonical" href="{{ meta.canonical }}">

  <meta property="og:type" content="profile">
  <meta property="og:title" content="{{ basics.name }} — CV">
  <meta property="og:description" content="{{ page_description }}">
  <meta property="og:image" content="{{ basics.image }}">
  <meta property="og:url" content="{{ meta.canonical }}">
  <meta name="twitter:card" content="summary_large_image">

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="assets/style.css">

  <script type="application/ld+json">
  {{ jsonld | safe }}
  </script>
</head>
<body>

  <!-- Hero -->
  <div class="profile-section">
    <img class="avatar" src="{{ basics.image }}" alt="{{ basics.name }}">
    <div class="tagline">
      <h1>{{ basics.name }}</h1>
      <p>{{ basics.label }}</p>
    </div>
  </div>

  <!-- Social / contact links -->
  <div class="social-links">
    {%- for p in basics.profiles %}
    <a href="{{ p.url }}" rel="me" target="_blank">
      <img src="https://cdn.jsdelivr.net/gh/simple-icons/simple-icons/icons/{{ p.x_icon }}.svg" alt="{{ p.network }}"> {{ p.network }}
    </a>
    {%- endfor %}
  </div>

  <main class="container">

    <div class="section">
      <h2>Summary</h2>
      <p>{{ basics.summary }}</p>
      <a class="btn" href="Nishanur_Rahman_CV.pdf" target="_blank">Download CV (PDF)</a>
    </div>

    <div class="section">
      <h2>Skills</h2>
      {%- for group in skills %}
      <div class="skill-group">
        <strong>{{ group.name }}:</strong>
        {%- for kw in group.keywords %}<span class="tag">{{ kw }}</span>{%- endfor %}
      </div>
      {%- endfor %}
    </div>

    <div class="section">
      <h2>Experience</h2>
      <div class="timeline">
        {%- for job in work %}
        <div class="timeline-item">
          <div class="when">{{ job.x_dateDisplay or (fmt_date(job.startDate) ~ ' – ' ~ (fmt_date(job.endDate) if job.endDate else 'Present')) }}</div>
          <h3>{{ job.position }}</h3>
          <div class="where">{{ job.name }}{% if job.location %} · {{ job.location }}{% endif %}{% if job.x_employment %} · {{ job.x_employment }}{% endif %}</div>
          {%- if job.highlights %}
          <ul>
            {%- for hi in job.highlights %}
            <li><strong>{{ hi.name }}:</strong> {{ hi.description }}</li>
            {%- endfor %}
          </ul>
          {%- endif %}
        </div>
        {%- endfor %}
      </div>
    </div>

    {%- if hackathons %}
    <div class="section">
      <h2>Hackathons</h2>
      <div class="timeline">
        {%- for h in hackathons %}
        <div class="timeline-item">
          <div class="when">{{ h.year }}</div>
          <h3>{{ h.name }}</h3>
          <div class="where">{{ h.event }} — <a href="{{ h.url }}" target="_blank">View idea</a></div>
          <p><em>{{ h.tagline }}</em></p>
          <ul>
            {%- for hi in h.highlights %}
            <li><strong>{{ hi.name }}:</strong> {{ hi.description }}</li>
            {%- endfor %}
          </ul>
          <p class="muted">Status: {{ h.status }}</p>
        </div>
        {%- endfor %}
      </div>
    </div>
    {%- endif %}

    <div class="section">
      <h2>Education</h2>
      <div class="timeline">
        {%- for ed in education %}
        <div class="timeline-item">
          <div class="when">{{ ed.x_dateDisplay or fmt_date(ed.endDate) }}</div>
          <h3>{{ ed.studyType }} — {{ ed.area }}</h3>
          <div class="where">{{ ed.institution }}{% if ed.location %} · {{ ed.location }}{% endif %}{% if ed.score %} · {{ ed.score }}{% endif %}</div>
          {%- if ed.courses %}
          <ul><li><strong>Relevant coursework:</strong> {{ ed.courses | join(', ') }}.</li></ul>
          {%- endif %}
        </div>
        {%- endfor %}
      </div>
    </div>

    <div class="section">
      <h2>Certifications &amp; Awards</h2>
      <h3>Certifications</h3>
      <ul>
        {%- for c in certificates %}
        <li>{{ c.name }}{% if c.issuer %} <span class="muted">— {{ c.issuer }}</span>{% endif %}</li>
        {%- endfor %}
      </ul>
      <p class="muted">Certifications are verifiable on my <a href="{{ profiles_by_network.LinkedIn.url }}" target="_blank">LinkedIn</a>.</p>
      <h3>Awards</h3>
      <ul>
        {%- for a in awards %}
        <li><strong>{{ a.title }}</strong> <span class="muted">— {{ a.awarder }}, {{ fmt_date(a.date) }}.</span> {{ a.summary }}</li>
        {%- endfor %}
      </ul>
    </div>

    {%- if publications %}
    <div class="section">
      <h2>Publications</h2>
      {%- for pub in publications %}
      <div class="timeline-item" style="padding-left:0;">
        <h3>{{ pub.name }}</h3>
        <div class="where">{{ pub.publisher }} · {{ pub.releaseDate }}</div>
        <p>{{ pub.summary }}</p>
        {%- if pub.url %}<a class="btn secondary" href="{{ pub.url }}" target="_blank">View Publication →</a>{%- endif %}
      </div>
      {%- endfor %}
    </div>
    {%- endif %}

    <div class="section">
      <h2>Volunteering</h2>
      <ul>
        {%- for v in volunteer %}
        <li><strong>{{ v.organization }}</strong> <span class="muted">— {{ v.location }}, {{ v.x_dateDisplay }}.</span> {{ v.summary }}</li>
        {%- endfor %}
      </ul>
    </div>

    <div class="section">
      <h2>Interests</h2>
      <p>{% for group in interests %}{{ group.keywords | join(' · ') }}{% endfor %}</p>
    </div>

  </main>

  <footer class="site-footer">
    <p>© {{ basics.name }} · Last updated {{ meta.lastModified }}</p>
  </footer>

</body>
</html>
